{
  "name": "@horizon-republic/nestjs-jetstream",
  "version": "2.1.0",
  "description": "A NestJS transport for NATS with JetStream events, broadcast fan-out, and Core/JetStream RPC.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HorizonRepublic/nestjs-jetstream.git"
  },
  "homepage": "https://github.com/HorizonRepublic/nestjs-jetstream#readme",
  "bugs": {
    "url": "https://github.com/HorizonRepublic/nestjs-jetstream/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "nestjs",
    "jetstream",
    "nats",
    "transport",
    "microservices",
    "rpc",
    "events"
  ],
  "author": {
    "name": "Horizon Republic",
    "url": "https://github.com/HorizonRepublic"
  },
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">= 20.19.0"
  },
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "build:example": "tsc -p examples/tsconfig.json",
    "start:example": "pnpm build && pnpm build:example && node dist-example/examples/main.js",
    "dev:example": "tsx --tsconfig examples/tsconfig.json examples/main.ts",
    "prepublishOnly": "pnpm build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.2.0 || ^11.0.0",
    "@nestjs/core": "^10.2.0 || ^11.0.0",
    "@nestjs/microservices": "^10.2.0 || ^11.0.0",
    "nats": "^2.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@golevelup/ts-jest": "^1.2.1",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/testing": "^11.1.16",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.4.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
